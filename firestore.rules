rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['username', 'metaObjective', 'salesHistory'])
        && data.keys().size() <= 6
        && data.username is string
        && data.username.size() >= 2
        && data.username.size() <= 64
        && data.metaObjective is int
        && data.metaObjective >= 1
        && data.metaObjective <= 2000
        && data.salesHistory is list
        && data.salesHistory.size() <= 1000
        && (!data.keys().hasAny(['metaPrepagoObjective']) || (data.metaPrepagoObjective is int && data.metaPrepagoObjective >= 1 && data.metaPrepagoObjective <= 2000))
        && (!data.keys().hasAny(['prepagosHistory']) || (data.prepagosHistory is list && data.prepagosHistory.size() <= 1000));
    }

    match /userProfiles/{username} {
      allow get, delete: if isValidId(username);
      allow create, update: if isValidId(username) && isValidUserProfile(request.resource.data);
      allow list: if true; // Allowed list queries to enable cross-device account selection
    }
  }
}
